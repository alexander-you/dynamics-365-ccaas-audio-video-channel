# Customer web entry point — environment template (placeholders only).
# Copy to `.env.local` and adjust. NEVER commit real values.
# Vite only exposes variables prefixed with VITE_ to the browser.

# Base URL of the token service. Empty string uses the Vite dev proxy (/api -> :7071).
# For a real two-party ACS test (C5), point this at the relay (which hosts POST /api/token):
#   VITE_TOKEN_SERVICE_BASE_URL=https://func-acv-byoc-relay-vnusoc.azurewebsites.net
VITE_TOKEN_SERVICE_BASE_URL=

# When true, the app runs fully client-side with fake devices and never instantiates
# the real ACS Calling SDK. Default. Set to false for a real ACS call joining the agent's group.
VITE_USE_MOCKS=true

# Optional: channel configuration name to request (alex_acvchannelconfig).
VITE_CHANNEL_CONFIG=default

# ACS group-call GUID to join. Must match the agent panel's VITE_ACS_GROUP_ID so both sides
# land in the same call. Defaults to the agent panel's default group when unset.
VITE_ACS_GROUP_ID=7a9f5c2e-0b1d-4e6a-9c3f-1a2b3c4d5e6f
