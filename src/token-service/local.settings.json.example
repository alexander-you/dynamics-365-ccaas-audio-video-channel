    "RECORDINGS_CONTAINER": "recordings",
    "RECORDINGS_STORAGE_AUTH": "ManagedIdentity",
    "RECORDING_STORAGE_MODE": "AzureBlobBYOS",

    "//": "------ Key Vault ------",
