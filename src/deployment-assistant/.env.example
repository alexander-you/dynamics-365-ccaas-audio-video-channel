# Deployment Assistant — environment template (placeholders only).
# Copy to `.env.local` and adjust. NEVER commit real values.
# Only VITE_-prefixed variables are exposed to the browser.
#
# IMPORTANT: The deployment assistant is a LOCAL prototype. It does NOT call Azure or
# Dynamics 365 and it does NOT store secrets. Do not paste connection strings, keys,
# tokens, or subscription IDs that you consider sensitive into the page or this file.

# Cosmetic default shown in the naming-convention preview. Not tenant-specific.
VITE_DEFAULT_PREFIX=acv

# Default workload short-name used in the naming convention (e.g., rg-<workload>-dev-weu).
VITE_DEFAULT_WORKLOAD=acv

# Default environment tag suggestion (dev | test | prod). Cosmetic only.
VITE_DEFAULT_ENV=dev

# Default Azure region suggestion shown pre-selected (cosmetic only; user confirms).
VITE_DEFAULT_REGION=westeurope
