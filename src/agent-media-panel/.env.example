# Agent Media Panel — local mock configuration (Phase 3c).
# Copy this file to .env.local (git-ignored). NEVER put real secrets, tokens, or tenant values here.

# Keep mock mode ON. The real ACS Calling SDK path is not implemented in Phase 3c.
VITE_USE_MOCKS=true

# Cosmetic placeholders for the mock "Related Case / Contact" panel (no real Dataverse data).
VITE_MOCK_CASE_NUMBER=CAS-01234-ABCDE
VITE_MOCK_CONTACT_NAME=Sample Customer
