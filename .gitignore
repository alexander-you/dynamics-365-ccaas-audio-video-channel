*.env
.env
.env.*
!.env.example
local.settings.json
appsettings.*.local.json
secrets.json
*.pfx
*.pem
*.key
*.publishsettings

# Private documentation (tenant / environment specific notes)
docs/private/**
!docs/private/README.md
!docs/private/*.template.md

